# =============================================================================
# Conduit Backend — Environment Variables (Example)
# =============================================================================

# Secret key shared between frontend and backend for AES-256 API encryption.
# Must be exactly 32 characters. Generate with: openssl rand -hex 16
# This maps to conduit.api.encryption.secret-key in application.yaml
CONDUIT_SECRET_KEY=your-32-character-secret-key-here

# (Optional) Override the port the backend server listens on.
# Defaults to 8080 if not set.
# CONDUIT_PORT=8080

# (Optional) Path to the Conduit data directory.
# Defaults to ~/.conduit if not set.
# CONDUIT_DATA_DIR=/home/youruser/.conduit
