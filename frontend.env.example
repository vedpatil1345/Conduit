# =============================================================================
# Conduit Frontend — Environment Variables (Example)
# =============================================================================

# Secret key shared with the backend for AES-256 API encryption.
# Must be exactly 32 characters. Generate with: openssl rand -hex 16
NEXT_PUBLIC_SECRET_KEY=your-32-character-secret-key-here

# Base URL of the Conduit backend.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
